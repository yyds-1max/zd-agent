APP_NAME=知达 Agent Demo
APP_ENV=dev
APP_PORT=8000

VECTOR_BACKEND=chroma
VECTOR_DIR=storage/vector
CHROMA_COLLECTION=knowledge_chunks
METADATA_DB=storage/sqlite/metadata.db
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TENANT_ACCESS_TOKEN=
FEISHU_USER_ID_TYPE=open_id
FEISHU_DEPARTMENT_ID_TYPE=open_department_id
FEISHU_HTTP_TIMEOUT=8.0
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=


EMBEDDING_MODEL=text-embedding-v4
CHAT_MODEL=qwen3-max
ANSWER_MODEL=qwen3-max
ENABLE_LLM_ANSWER_GENERATION=true
VERSION_DIFF_MODEL=qwen3-max
ENABLE_LLM_VERSION_DIFF=true
CHAT_CONCLUSION_MODEL=qwen3-max
ENABLE_LLM_CHAT_CONCLUSION=false
RERANK_MODEL=gte-rerank
ENABLE_MODEL_RERANK=false
DASHSCOPE_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=

TEXT_CHUNK_SIZE=500
TEXT_CHUNK_OVERLAP=80

ENABLE_PUSH=false
